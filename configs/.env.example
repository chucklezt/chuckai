# Copy this file to .env and fill in real values. Never commit .env to git.

# SearXNG secret key — required or SearXNG crashes on startup.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SEARXNG_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# OpenAI API key — dummy value for llama.cpp OpenAI-compatible endpoint.
# Only needed if connecting to a real OpenAI API; llama.cpp accepts any value.
OPENAI_API_KEY=dummy
